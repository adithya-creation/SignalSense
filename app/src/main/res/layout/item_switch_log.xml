<?xml version="1.0" encoding="utf-8"?>
<!--
    log-item from Lovable history.tsx spec
    [dot] [5G SA] [->] [4G]          [10:42 AM]
-->
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="12dp"
    android:layout_marginBottom="6dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp"
    app:cardBackgroundColor="@color/bg_card"
    app:strokeWidth="1dp"
    app:strokeColor="@color/card_border">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="14dp"
        android:paddingVertical="14dp">

        <!-- Coloured dot -->
        <View
            android:id="@+id/viewNetworkDot"
            android:layout_width="7dp"
            android:layout_height="7dp"
            android:background="@drawable/bg_dot_circle"
            tools:backgroundTint="@color/accent" />

        <!-- Transition label -->
        <TextView
            android:id="@+id/tvTransition"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:textSize="13sp"
            android:fontFamily="@font/geist"
            android:textColor="@color/text_primary"
            tools:text="5G SA to 4G" />

        <!-- Push timestamp to right -->
        <Space
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

        <!-- Timestamp + optional speed -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="end">

            <TextView
                android:id="@+id/tvTimestamp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="10sp"
                android:fontFamily="@font/geist"
                android:textColor="@color/text_secondary"
                tools:text="10:42 AM" />

            <TextView
                android:id="@+id/tvSpeed"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textSize="9sp"
                android:fontFamily="@font/geist"
                android:textColor="@color/text_muted"
                android:visibility="gone"
                tools:text="32.5 Mbps"
                tools:visibility="visible" />
        </LinearLayout>
    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
