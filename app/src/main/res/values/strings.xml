    <!-- Background Restrictions Check Dialog -->
    <string name="oem_dialog_title">Background Restrictions Check</string>
    <string name="oem_dialog_btn_open_settings">Open Settings</string>
    <string name="oem_dialog_btn_not_now">Not Now</string>
    <string name="oem_dialog_body_generic">Battery optimization is disabled for SignalSense.\n\nSignalSense is allowed to run without Android battery restrictions. If monitoring or alerts become unreliable, verify that your device does not apply additional background restrictions.</string>
    <string name="oem_dialog_body_samsung">Battery optimization is disabled for SignalSense.\n\nHowever, Samsung devices may place background apps into \'Deep Sleep\'.\n\nTo ensure reliable operation, consider adding SignalSense to \'Never sleeping apps\' under Battery settings.</string>
    <string name="oem_dialog_body_other_oems">Battery optimization is disabled for SignalSense.\n\nHowever, some devices (Xiaomi, Redmi, POCO, OPPO, Realme, OnePlus, and Vivo) may apply additional background restrictions that can affect automatic monitoring and alerts.\n\nTo ensure reliable operation, verify that SignalSense is allowed to run unrestricted in the background.</string>
